diario = []

while True:
  entrada = input('Digite sua entrada diária: ')

  if entrada == '0':
    break

  diario.append(entrada)

with open('diario.txt', 'w') as arquivo:
  for nota in diario:
    arquivo.write(f'{nota} \n')

with open ('diario.txt','r') as arquivo: 
  conteudo = arquivo.read()

  print(conteudo)      

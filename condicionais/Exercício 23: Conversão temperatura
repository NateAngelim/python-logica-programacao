temperatura = float(input("Digite a temperatura: "))
escala = input(
    "Digite C se a temperatura está em Celsius ou F se está em Fahrenheit: "
).upper()

if escala == "C":
    fahrenheit = (temperatura * 1.8) + 32
    print(f"{temperatura:.2f}°C = {fahrenheit:.2f}°F")

elif escala == "F":
    celsius = (temperatura - 32) / 1.8
    print(f"{temperatura:.2f}°F = {celsius:.2f}°C")

else:
    print("Escala inválida.")

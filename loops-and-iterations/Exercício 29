while True:
  aluno = input('Digite o nome do aluno(a): ').upper()
  if aluno == '0':
    break
  nota = float(input('Digite a nota do aluno(a): '))
  if nota < 0 or nota > 10:
    print('Nota inválida, digite um número de 0 a 10.')

  if nota < 4:
    print(f'O aluno(a) {aluno} foi reprovado(a).')
  elif nota < 6:
    print(f'O aluno(a) {aluno} esta de recuperação.')  
  elif nota <=10: 
    print(f'O aluno(a) {aluno} foi aprovado(a).') 

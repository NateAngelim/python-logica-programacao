#1 -> candidato 1
#2 -> candidato 2
#3 -> candidato 3
#0 -> encerrar votação
voto = int(input("Digite o voto: "))
votos_candidato1 = 0
votos_candidato2 = 0
votos_candidato3 = 0
voto_nulo = 0

while voto != 0:
  
  if voto == 1:
    votos_candidato1 +=1

  elif voto == 2:
    votos_candidato2 +=1

  elif voto == 3:
    votos_candidato3 +=1 

  else:
    voto_nulo +=1   

  voto = int(input("Digite o seu voto: "))
print(f'(O candidato 1 teve: {votos_candidato1} votos.)')
print(f'(O candidato 2 teve: {votos_candidato2} votos.)')
print(f'(O candidato 3 teve: {votos_candidato3} votos.)')
print(f'(Tiveram: {voto_nulo} votos nulos.)')

if votos_candidato1 > votos_candidato2 and votos_candidato1 > votos_candidato3:
  print('O candidato 1 foi o vencedor!')

elif votos_candidato2 > votos_candidato1 and votos_candidato2 > votos_candidato3:
  print('O candidato 2 foi o vencedor!') 

elif votos_candidato1 == votos_candidato2 or votos_candidato2 == votos_candidato3 or votos_candidato1 == votos_candidato3 :  
  print('Houve empate, haverá segundo turno.')

else:
  print('O candidato 3 foi o vencedor!') 
